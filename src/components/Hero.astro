---
import { Image } from "astro:assets";
import headshot from "../assets/headshot.jpg";
import { site } from "../data/site";
---

<section class="pt-12 sm:pt-16">
  <div class="flex flex-col-reverse sm:flex-row sm:items-center gap-6 sm:gap-8">
    <div class="flex-1 min-w-0">
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-[var(--color-fg)] dark:text-[var(--color-fg-dark)]">
        {site.name}
      </h1>
      <p class="mt-2 text-[var(--color-fg)] dark:text-[var(--color-fg-dark)]">
        {site.jobTitle} at {site.employer}
      </p>
      <p class="mt-1 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
        {site.tagline}
      </p>

      <ul class="mt-5 flex flex-wrap gap-2 text-sm">
        <li>
          <a
            href={`mailto:${site.email}`}
            class="inline-flex items-center px-3 py-1.5 rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-dark)] transition-colors"
            >Email</a
          >
        </li>
        <li>
          <a
            href={site.links.linkedin}
            target="_blank"
            rel="me noopener noreferrer"
            class="inline-flex items-center px-3 py-1.5 rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-dark)] transition-colors"
            >LinkedIn</a
          >
        </li>
        <li>
          <a
            href={site.links.github}
            target="_blank"
            rel="me noopener noreferrer"
            class="inline-flex items-center px-3 py-1.5 rounded-full border border-[var(--color-border)] dark:border-[var(--color-border-dark)] hover:border-[var(--color-accent)] dark:hover:border-[var(--color-accent-dark)] transition-colors"
            >GitHub</a
          >
        </li>
      </ul>
    </div>

    <div class="shrink-0">
      <Image
        src={headshot}
        alt={`Portrait of ${site.name}`}
        width={120}
        height={120}
        densities={[1, 2]}
        quality={90}
        loading="eager"
        class="rounded-full size-[120px] object-cover border border-[var(--color-border)] dark:border-[var(--color-border-dark)]"
      />
    </div>
  </div>
</section>
